<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - assestment</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assestment.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #FAFAF8;
        }
        .navbar {
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
        }
        .navbar-brand {
            font-weight: 600;
            letter-spacing: -0.01em;
        }
        .nav-link {
            font-weight: 500;
            font-size: 0.95rem;
        }
        .nav-link.active {
            color: var(--bs-primary) !important;
        }
        .kyc-pill {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
            border-radius: 999px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fs-5" asp-area="" asp-controller="Property" asp-action="Index">
                    <i class="bi bi-house-door-fill text-primary me-1"></i>Tu reserva
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Property" asp-action="Index">
                                Explorar
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Propietario"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Property" asp-action="MyProperties">
                                    Mis inmuebles
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                    Metricas
                                </a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Huesped"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Reservation" asp-action="MyReservations">
                                    Mis reservas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Favorite" asp-action="Index">
                                    Mis favoritos
                                </a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Kyc" asp-action="Verify">
                                   
                                    <i class="bi bi-patch-check me-1"></i>Confirmar identidad
                                </a>
                            </li>
                        }
                    </ul>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-3 mt-3 mt-md-0">
                            <span class="text-muted small">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                            <form method="post" asp-controller="Auth" asp-action="Logout" class="d-inline m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Cerrar sesión</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2 mt-3 mt-md-0">
                            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary btn-sm">Iniciar sesión</a>
                            <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-sm">Crear cuenta</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top py-4 text-muted">
        <div class="container d-flex justify-content-between small">
            <span>&copy; 2026 assestment</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>