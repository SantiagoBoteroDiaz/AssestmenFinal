@model ICollection<assestment.Models.Inmueble>
@{
    ViewData["Title"] = "Mis favoritos";
}

<div class="container py-4">
    <h1 class="h3 mb-4">Mis favoritos</h1>

    @if (TempData["FavoriteError"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["FavoriteError"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5 mb-1">Aún no tienes alojamientos guardados.</p>
            <p class="text-muted mb-3">Marca como favorito los que te interesen mientras explores.</p>
            <a asp-controller="Property" asp-action="Index" class="btn btn-primary">
                Explorar alojamientos
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var inmueble in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <a asp-controller="Property" asp-action="Details" asp-route-id="@inmueble.Id"
                           class="text-decoration-none text-reset">
                            @if (!string.IsNullOrEmpty(inmueble.UrlImagen))
                            {
                                <img src="@inmueble.UrlImagen" class="card-img-top" alt="@inmueble.Titulo"
                                     style="height: 180px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center"
                                     style="height: 180px;">
                                    <span class="text-muted small">Sin foto disponible</span>
                                </div>
                            }
                            <div class="card-body pb-2">
                                <h2 class="h5 card-title mb-1">@inmueble.Titulo</h2>
                                <p class="text-muted small mb-2">
                                    <i class="bi bi-geo-alt"></i> @inmueble.Ubicacion
                                </p>
                                <p class="fw-semibold mb-0">
                                    @inmueble.TarifaPorNoche.ToString("C0") <span class="text-muted small fw-normal">/ noche</span>
                                </p>
                            </div>
                        </a>
                        <div class="card-body pt-0">
                            <form method="post" asp-controller="Favorite" asp-action="Remove">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propertyId" value="@inmueble.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                    <i class="bi bi-heart-fill"></i> Quitar de favoritos
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>