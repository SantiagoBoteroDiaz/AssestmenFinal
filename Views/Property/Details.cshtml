@model assestment.Models.Inmueble
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="container py-4">
    <div class="row">
        <div class="col-12 col-lg-8">
            @if (!string.IsNullOrEmpty(Model.UrlImagen))
            {
                <img src="@Model.UrlImagen" class="img-fluid rounded-3 mb-4" alt="@Model.Titulo"
                     style="width: 100%; height: 380px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center rounded-3 mb-4"
                     style="height: 380px;">
                    <span class="text-muted">Sin foto disponible</span>
                </div>
            }

            <h1 class="h3 mb-1">@Model.Titulo</h1>
            <p class="text-muted mb-4">
                <i class="bi bi-geo-alt"></i> @Model.Ubicacion
            </p>

            <h2 class="h5 mb-2">Descripción</h2>
            <p class="mb-4">@Model.Descripcion</p>

            <h2 class="h5 mb-2">Política de horarios</h2>
            <p class="text-muted mb-0">
                <i class="bi bi-clock"></i> Check-in 2:00 PM &middot; Check-out 12:00 PM
            </p>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 1rem;">
                <div class="card-body">
                    <p class="fs-4 fw-semibold mb-3">
                        @Model.TarifaPorNoche.ToString("C0")
                        <span class="text-muted small fw-normal">/ noche</span>
                    </p>

                    @if (TempData["ReservationError"] != null)
                    {
                        <div class="alert alert-warning small" role="alert">
                            @TempData["ReservationError"]
                        </div>
                    }

                    @if (TempData["FavoriteError"] != null)
                    {
                        <div class="alert alert-warning small" role="alert">
                            @TempData["FavoriteError"]
                        </div>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Huesped"))
                        {
                            <form method="post" asp-controller="Reservation" asp-action="Create" class="mb-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="PropertyId" value="@Model.Id" />

                                <div class="mb-3">
                                    <label for="CheckIn" class="form-label small">Check-in</label>
                                    <input type="date" id="CheckIn" name="CheckIn" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label for="CheckOut" class="form-label small">Check-out</label>
                                    <input type="date" id="CheckOut" name="CheckOut" class="form-control" required />
                                </div>

                                <button type="submit" class="btn btn-primary w-100">Reservar</button>
                            </form>

                            <form method="post" asp-controller="Favorite" asp-action="Add">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propertyId" value="@Model.Id" />
                                <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Property", new { id = Model.Id })" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                    <i class="bi bi-heart"></i> Guardar en favoritos
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="text-center py-2">
                                <i class="bi bi-info-circle text-muted fs-4"></i>
                                <p class="text-muted small mb-0 mt-2">
                                    Esta cuenta es de propietario y no puede realizar reservas.
                                </p>
                            </div>
                        }
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login"
                           asp-route-returnUrl="@Url.Action("Details", "Property", new { id = Model.Id })"
                           class="btn btn-primary w-100 mb-2">
                            Inicia sesión para reservar
                        </a>
                        <p class="text-muted small text-center mb-0">
                            También necesitas una cuenta para guardar favoritos
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>