@model ICollection<assestment.Models.Inmueble>
@{
    ViewData["Title"] = "Mis inmuebles";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Mis inmuebles</h1>
        <a asp-controller="Property" asp-action="Create" class="btn btn-primary">
            Publicar nuevo inmueble
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5 mb-1">Aún no has publicado ningún inmueble.</p>
            <p class="text-muted mb-3">Publica el primero para empezar a recibir reservas.</p>
            <a asp-controller="Property" asp-action="Create" class="btn btn-primary">
                Publicar inmueble
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var inmueble in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(inmueble.UrlImagen))
                        {
                            <img src="@inmueble.UrlImagen" class="card-img-top" alt="@inmueble.Titulo"
                                 style="height: 180px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height: 180px;">
                                <span class="text-muted small">Sin foto disponible</span>
                            </div>
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h2 class="h5 card-title mb-0">@inmueble.Titulo</h2>
                                @if (inmueble.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </div>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt"></i> @inmueble.Ubicacion
                            </p>
                            <p class="fw-semibold mb-3">
                                @inmueble.TarifaPorNoche.ToString("C0") <span class="text-muted small fw-normal">/ noche</span>
                            </p>

                            <div class="d-flex gap-2">
                                <a asp-controller="Property" asp-action="Details" asp-route-id="@inmueble.Id"
                                   class="btn btn-outline-secondary btn-sm flex-grow-1">
                                    Ver detalle
                                </a>
                                
                                <a asp-controller="Property" asp-action="Edit" asp-route-id="@inmueble.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1">
                                    Editar
                                </a>    

                                @if (inmueble.Activo)
                                {
                                    <form method="post" asp-controller="Property" asp-action="Deactivate"
                                          asp-route-id="@inmueble.Id" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                            Desactivar
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>